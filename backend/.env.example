# === Django ===
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# === Base de données ===
# sqlite (dev legacy) | postgresql (recommandé)
DB_ENGINE=postgresql
DB_NAME=sghl
DB_USER=sghl
DB_PASSWORD=sghl
DB_HOST=localhost
DB_PORT=5432

# === Cache Redis (KPIs dashboard) ===
# REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# === CORS (front staff :5173, admin :5174, mobile Flutter web :8080) ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:8080

# === Chiffrement fichiers (Fernet — obligatoire en prod) ===
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# === SMTP Gmail (OTP inscription, RDV, notifications) ===
# Mot de passe d'application Google (16 caractères, sans espaces) — pas le mot de passe du compte
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre.email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=votre.email@gmail.com
